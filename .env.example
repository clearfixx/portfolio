# Database
DATABASE_URL=postgres://portfolio:portfolio@127.0.0.1:5434/portfolio

# Payload
PAYLOAD_SECRET=replace-with-a-secure-random-secret

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public API abuse protection.
# Leave PUBLIC_API_TRUSTED_IP_HEADER empty unless the app is behind a
# trusted reverse proxy that overwrites this header.
# Supported values: cf-connecting-ip, x-vercel-forwarded-for,
# x-real-ip, x-forwarded-for
PUBLIC_API_TRUSTED_IP_HEADER=
PUBLIC_API_RATE_LIMIT_SECRET=

# DSS GitHub Feed
# Optional server-side GitHub token. Recommended for higher API limits.
DSS_GITHUB_TOKEN=
# Optional bearer secret for machine-to-machine manual synchronization.
DSS_GITHUB_FEED_SYNC_SECRET=
