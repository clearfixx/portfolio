# Database
DATABASE_URL=postgres://portfolio:portfolio@127.0.0.1:5434/portfolio

# Payload
PAYLOAD_SECRET=replace-with-a-secure-random-secret

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public API abuse protection.
# Leave PUBLIC_API_TRUSTED_IP_HEADER empty unless the app is behind a
# trusted reverse proxy that overwrites this header.
# Supported values: cf-connecting-ip, x-vercel-forwarded-for,
# x-real-ip, x-forwarded-for
PUBLIC_API_TRUSTED_IP_HEADER=
PUBLIC_API_RATE_LIMIT_SECRET=

# DSS GitHub Feed
# Optional server-side GitHub token. Recommended for higher API limits.
DSS_GITHUB_TOKEN=
# Optional bearer secret for machine-to-machine manual synchronization.
DSS_GITHUB_FEED_SYNC_SECRET=

# DSS X Feed
# Optional pay-per-use official X API bearer token.
# Required only when the configured source uses Official X API or a fallback
# chain that includes it.
DSS_X_BEARER_TOKEN=

# Optional Authorization header for a protected/self-hosted RSSHub instance.
# Example: Basic <base64-credentials>
DSS_X_RSSHUB_AUTHORIZATION=

# Optional bearer secret for machine-to-machine manual synchronization.
DSS_X_FEED_SYNC_SECRET=

# DSS Instagram Feed

# Official source.
# Required only when the configured source uses the official Instagram API
# or a fallback chain that includes it.
DSS_INSTAGRAM_ACCESS_TOKEN=
DSS_INSTAGRAM_USER_ID=

# Experimental web-session source.
# Both values must come from the same active logged-in Instagram session.
# Never commit live session credentials.
DSS_INSTAGRAM_SESSION_ID=
DSS_INSTAGRAM_CSRF_TOKEN=

# Optional experimental source overrides.
DSS_INSTAGRAM_DS_USER_ID=
DSS_INSTAGRAM_APP_ID=936619743392459
DSS_INSTAGRAM_USER_AGENT=
DSS_INSTAGRAM_GRAPHQL_DOC_ID=25403009626063073

# Optional bearer secret for machine-to-machine manual synchronization.
DSS_INSTAGRAM_FEED_SYNC_SECRET=
